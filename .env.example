# Token Bearer usado pelo ERP para acessar esta API central.
API_SECRET_TOKEN=troque-por-um-token-longo-e-aleatorio

# Credenciais da API Avançada do Fracttal. Prefira KEY + SECRET.
FRACTTAL_BASIC_KEY=
FRACTTAL_BASIC_SECRET=
# Alternativa: token Base64 pronto, com ou sem o prefixo "Basic ".
FRACTTAL_BASIC_TOKEN=
FRACTTAL_BASE_URL=https://app.fracttal.com/api

# OCR/transcrição de prints e PDFs escaneados. A IA apenas transcreve;
# a decisão de autorização continua determinística no ERP.
DOCUMENT_GEMINI_API_KEY=
DOCUMENT_GEMINI_MODEL=gemini-2.5-flash-lite
DOCUMENT_OCR_WITH_GEMINI=true

# Limites de segurança e desempenho.
MAX_ATTACHMENTS_PER_REQUEST=20
MAX_ATTACHMENT_BYTES=12582912
MAX_PDF_PAGES=20
ATTACHMENT_WORKERS=3
ATTACHMENT_PREVIEW_TTL_SECONDS=14400
HTTP_CONNECT_TIMEOUT=10
HTTP_READ_TIMEOUT=45
HTTP_MAX_RETRIES=3
FRACTTAL_MAX_PAGES=20
ALLOWED_ATTACHMENT_HOSTS=fracttal-fs.s3.amazonaws.com,.amazonaws.com,.fracttal.com,.cloudfront.net

# Habilite somente temporariamente se precisar abrir /docs no Render.
ENABLE_API_DOCS=false
